# =========================================================================
# MODÈLE DE CONFIGURATION (.env.example)
# Copiez ce fichier vers .env et remplissez les valeurs
# =========================================================================
# 💡 Architecture Multi-Pays :
#   1 codebase → N projets Vercel → N domaines
#   Seul ce fichier .env change entre les instances.
# =========================================================================

# --- IDENTITÉ DE L'INSTANCE ---
NEXT_PUBLIC_SITE_NAME="My Shop"
NEXT_PUBLIC_SITE_DESCRIPTION="Your modern e-commerce store."
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CORS_ORIGIN=http://localhost:3000

# --- CONFIGURATION MULTI-PAYS ---
# Pays principal (ISO 3166-1 alpha-2 : CA, US, FR, DE, GB, MX, ...)
NEXT_PUBLIC_COUNTRY=CA
# Devise (ISO 4217 : CAD, USD, EUR, GBP, ...)
NEXT_PUBLIC_CURRENCY=CAD
# Langue par défaut
NEXT_PUBLIC_DEFAULT_LOCALE=en
# Langues supportées (séparées par des virgules)
NEXT_PUBLIC_LOCALES=en,fr

# --- BASE DE DONNÉES ---
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# --- AUTHENTIFICATION (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
CLERK_TEST_USER_ID=user_...

# --- PAIEMENTS (Stripe) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Activer Stripe Tax (calcul automatique des taxes par pays)
STRIPE_AUTOMATIC_TAX=true

# --- EMAILS (Resend) ---
RESEND_API_KEY=re_...
FROM_EMAIL="My Shop <onboarding@resend.dev>"
ADMIN_EMAIL=admin@example.com
ADMIN_LOCALE=en

# --- LIVRAISON & LOGISTIQUE (Shippo) ---
SHIPPO_API_KEY=shippo_test_...
SHIPPO_UPS_ACCOUNT_ID=...
SHIPPO_WEBHOOK_TOKEN=whsec_...
# Transporteurs autorisés (séparés par des virgules, vide = tous)
# SHIPPING_PROVIDERS=ups,usps

# --- STOCKAGE MÉDIAS (Local / S3 / Cloudinary) ---
STORAGE_PROVIDER=local
STORAGE_LOCAL_UPLOAD_DIR=public/uploads
STORAGE_LOCAL_PUBLIC_PATH=/uploads

# Si utilisation S3
# STORAGE_PROVIDER=s3
# STORAGE_S3_BUCKET=mon-bucket
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY_ID=...
# STORAGE_S3_SECRET_ACCESS_KEY=...
# STORAGE_S3_ENDPOINT=https://...

# --- ANALYTICS & SERVICES EXTERNES ---
NEXT_PUBLIC_GTM_ID=GTM-...
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# --- PERFORMANCE & CACHE ---
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# --- DÉVELOPPEMENT & LOGS ---
NODE_ENV=development
LOG_LEVEL=info
# TEST_API_KEY=...
# ENABLE_SHIPPING_TEST_MODE=true